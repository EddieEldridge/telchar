{
  "name": "telchar",
  "version": "1.0.0",
  "scripts": {
    "dev": "tauri dev",
    "start": "vite",
    "rls": "tauri build",
    "rls:debug": "tauri build --debug",
    "rls:mac": "tauri build --target universal-apple-darwin",
    "build": "cross-env INLINE_RUNTIME_CHUNK=true NODE_OPTIONS=--max-old-space-size=16192 yarn vite build",
    "preview": "vite preview",
    "serve": "serve -s build",
    "preinstall": "yarn global add serve"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@chakra-ui/icons": "^2.0.17",
    "@chakra-ui/react": "^2.5.3",
    "@emotion/react": "11.10.6",
    "@emotion/styled": "11.10.6",
    "@fontsource/montserrat": "^4.5.14",
    "@tauri-apps/api": "^1.0.1",
    "framer-motion": "10.8.5",
    "localforage": "^1.10.0",
    "mutative": "^0.4.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.8.0",
    "react-router-dom": "^6.9.0",
    "tauri-plugin-store-api": "github:tauri-apps/tauri-plugin-store",
    "typescript": "^5.0.2",
    "zustand": "^4.3.6"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@rollup/plugin-inject": "^5.0.3",
    "@tauri-apps/cli": "^1.2.3",
    "@types/node": "^18.15.7",
    "@types/react-dom": "^18.0.11",
    "@vitejs/plugin-react": "^3.1.0",
    "buffer": "^6.0.3",
    "cross-env": "^7.0.3",
    "rollup-plugin-polyfill-node": "^0.12.0",
    "rollup-plugin-visualizer": "^5.6.0",
    "vite": "^4.2.1"
  }
}
